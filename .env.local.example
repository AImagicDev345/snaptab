# SnapTab environment (all free-tier services)
# Copy this to .env.local and fill in real values.

# --- Supabase (Free tier) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
# Server-only. Never ship to the browser. Used by server actions to bypass RLS for writes.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# --- Upstash Redis (Free tier) — rate limiting ---
UPSTASH_REDIS_REST_URL=https://YOUR-INSTANCE.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_TOKEN

# --- Sentry (Free Developer tier) ---
SENTRY_DSN=https://YOUR@sentry.io/PROJECT
NEXT_PUBLIC_SENTRY_DSN=https://YOUR@sentry.io/PROJECT

# --- PostHog (Free tier) — anonymous analytics ---
NEXT_PUBLIC_POSTHOG_KEY=phc_YOUR_KEY
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- App ---
NEXT_PUBLIC_APP_URL=https://snaptab.vercel.app
